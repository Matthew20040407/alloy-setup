// ─────────────────────────────────────────────
// Docker container log 來源
// ─────────────────────────────────────────────
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
  rule {
    source_labels = ["__meta_docker_container_image"]
    target_label  = "image"
  }
  rule {
    target_label = "job"
    replacement  = "docker"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.router.receiver]
}

// ─────────────────────────────────────────────
// 系統 log
// ─────────────────────────────────────────────
local.file_match "system_logs" {
  path_targets = [{
    __path__ = "/var/log/*.log",
    job      = "system",
  }]
}

loki.source.file "system_logs" {
  targets    = local.file_match.system_logs.targets
  forward_to = [loki.write.default.receiver]
}

// ─────────────────────────────────────────────
// 應用程式 log
// ─────────────────────────────────────────────
local.file_match "app_logs" {
  path_targets = [{
    __path__ = "/app/logs/*.log",
    job      = "app",
  }]
}

loki.source.file "app_logs" {
  targets    = local.file_match.app_logs.targets
  forward_to = [loki.process.router.receiver]
}

// ─────────────────────────────────────────────
// SIP Server log (container)
// ─────────────────────────────────────────────

loki.process "sip_logs" {

  // ── SIP 事件: > INVITE/ACK/BYE from (IP) (call_id=xxx) ──
  stage.match {
    selector = "{container=\"sip_server\"}"
    stage.regex {
      expression = "^> (?P<sip_method>INVITE|ACK|BYE|CANCEL|OPTIONS|REGISTER) from \\('(?P<remote_ip>[\\d\\.]+)', (?P<remote_port>\\d+)\\)(?: \\(call_id=(?P<call_id>\\S+)\\))?$"
    }
    stage.labels {
      values = {
        sip_method = "",
        remote_ip  = "",
        call_id    = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "sip" }
    }
  }

  // ── Transcription 完成: language, probability, duration ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^Transcription complete in (?P<transcription_duration>[\\d\\.]+)s \\(language: (?P<lang>\\w+), probability: (?P<lang_prob>[\\d\\.]+)\\)$"
    }
    stage.labels {
      values = {
        lang                  = "",
        lang_prob             = "",
        transcription_duration = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "stt" }
    }
  }

  // ── LLM HTTP 請求成功 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^HTTP Request: (?P<http_method>\\w+) (?P<llm_url>\\S+) \"HTTP/[\\d\\.]+ (?P<status_code>\\d+) [^\"]+\"$"
    }
    stage.labels {
      values = {
        http_method = "",
        status_code = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "llm_request" }
    }
  }

  // ── LLM 回應內容 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^LLM Response: (?P<llm_response>.+)$"
    }
    stage.labels {
      values = { llm_response = "" }
    }
    stage.static_labels {
      values = { level = "info", event_type = "llm_response" }
    }
  }

  // ── LLM 錯誤: 500 / 429 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^Chat failed: (?:Server|Client) error '(?P<status_code>\\d+) [^']+' for url '(?P<llm_url>[^']+)'$"
    }
    stage.labels {
      values = {
        status_code = "",
        llm_url     = "",
      }
    }
    stage.static_labels {
      values = { level = "error", event_type = "llm_error" }
    }
  }

  // ── Python Traceback ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "(?P<traceback>Traceback \\(most recent call last\\))"
    }
    stage.static_labels {
      values = { level = "error", event_type = "exception" }
    }
  }

  // ── RTP 封包 (noise，drop 掉，不需要進 Loki) ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.drop {
      expression = "^\\[SEND ACTIVE\\]|^\\[RTP-RECV\\]|^\\[WS\\] Incoming RTP|^Handling RTP for|^base64_string"
    }
  }

  // ── Call 生命週期事件 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^(?P<call_event>Call started|Call ended|Call .* terminated|> Session ended|> Saving received audio|> RTP session ready|> Sent 200 OK|RING_ANS|> Calling): ?(?P<call_id>\\S+)?"
    }
    stage.labels {
      values = {
        call_event = "",
        call_id    = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "call_lifecycle" }
    }
  }

  // ── STT 語言偵測 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^Detected language '(?P<detected_lang>\\w+)' with probability (?P<detect_prob>[\\d\\.]+)$"
    }
    stage.labels {
      values = {
        detected_lang = "",
        detect_prob   = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "lang_detect" }
    }
  }

  // ── Unsupported language fallback ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^Unsupported language got: (?P<unsupported_lang>\\w+)"
    }
    stage.labels {
      values = { unsupported_lang = "" }
    }
    stage.static_labels {
      values = { level = "warn", event_type = "lang_fallback" }
    }
  }

  // ── TTS 合成 ──
  stage.match {
    selector = "{job=\"sip_server\"}"
    stage.regex {
      expression = "^(?:Synthesizing in (?P<tts_lang>\\w+)|TTS audio saved to: (?P<tts_file>\\S+))"
    }
    stage.labels {
      values = {
        tts_lang = "",
        tts_file = "",
      }
    }
    stage.static_labels {
      values = { level = "info", event_type = "tts" }
    }
  }

  forward_to = [loki.write.default.receiver]
}

// ─────────────────────────────────────────────
// 解析路由 — 依 container label 分流
// ─────────────────────────────────────────────
loki.process "router" {

  // ── Redis ──────────────────────────────────
  // 格式: 1:M 24 Mar 2026 06:23:14.212 * <search> message
  // 格式: 1:M 24 Mar 2026 06:23:14.212 # WARNING: message
  stage.match {
    selector = "{container=\"redis_cache\"}"

    stage.regex {
      expression = "^(?P<pid>\\d+):(?P<role>[A-Z]) (?P<timestamp>\\d+ \\w+ \\d+ \\d+:\\d+:\\d+\\.\\d+) (?P<level_char>[*#-]) (?:(?P<module><[^>]+>) )?(?P<message>.+)$"
    }

    // * = info, # = warning, - = verbose
    stage.template {
      source   = "level"
      template = "{{ if eq .level_char \"#\" }}warn{{ else if eq .level_char \"*\" }}info{{ else }}debug{{ end }}"
    }

    stage.labels {
      values = {
        level  = "",
        role   = "",
        module = "",
      }
    }

    stage.label_drop {
      values = ["level_char"]
    }
  }

  // ── RAG App ────────────────────────────────
  // 格式: 2026-03-24 06:27:52,350 - app.services.rag_engine - INFO - message
  // 格式: INFO:     172.20.0.1:34476 - "POST /api/v1/chat/ HTTP/1.1" 200 OK
  stage.match {
    selector = "{container=\"rag_app\"}"

    stage.regex {
      expression = "^(?P<timestamp>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\d+) - (?P<logger>[\\w\\.]+) - (?P<level>\\w+) - (?P<message>.+)$"
    }

    stage.template {
      source   = "level"
      template = "{{ lower .level }}"
    }

    stage.labels {
      values = {
        level  = "",
        logger = "",
      }
    }
  }

  // HTTP access log 行 (uvicorn style)
  stage.match {
    selector = "{container=\"rag_app\"}"

    stage.regex {
      expression = "^(?P<level>INFO|WARNING|ERROR):\\s+(?P<client_ip>[\\d\\.]+):(?P<client_port>\\d+) - \"(?P<method>\\w+) (?P<path>[^\"]+) HTTP/(?P<http_version>[\\d\\.]+)\" (?P<status_code>\\d+)"
    }

    stage.labels {
      values = {
        level       = "",
        method      = "",
        status_code = "",
      }
    }
  }

  // ── RAG Cache App ──────────────────────────
  // 格式: INFO:     127.0.0.1:52142 - "GET /health HTTP/1.1" 200 OK
  stage.match {
    selector = "{container=\"rag-cache-server\"}"

    stage.regex {
      expression = "^(?P<level>INFO|WARNING|ERROR):\\s+(?P<client_ip>[\\d\\.]+):(?P<client_port>\\d+) - \"(?P<method>\\w+) (?P<path>[^\"]+) HTTP/(?P<http_version>[\\d\\.]+)\" (?P<status_code>\\d+)"
    }

    stage.labels {
      values = {
        level       = "",
        method      = "",
        status_code = "",
      }
    }

    // 過濾掉 /health check，避免 noise
    stage.drop {
      expression = ".*GET /health.*"
    }
  }

  // ── Qdrant ─────────────────────────────────
  // 格式: 2026-03-24T06:23:32.385093Z  INFO actix_web::middleware::logger: IP "METHOD path HTTP/x.x" status bytes "-" "agent" duration
  stage.match {
    selector = "{container=\"qdrant_db\"}"

    stage.regex {
      expression = "^(?P<timestamp>\\S+)\\s+(?P<level>\\w+) (?P<logger>[\\w:]+): (?P<client_ip>[\\d\\.]+) \"(?P<method>\\w+) (?P<path>\\S+) HTTP/(?P<http_version>[\\d\\.]+)\" (?P<status_code>\\d+) (?P<bytes>\\d+) \"[^\"]*\" \"(?P<user_agent>[^\"]+)\" (?P<duration>[\\d\\.]+)"
    }

    stage.template {
      source   = "level"
      template = "{{ lower .level }}"
    }

    stage.labels {
      values = {
        level       = "",
        method      = "",
        status_code = "",
        path        = "",
      }
    }

    // 計算 duration_ms 方便後續 metric
    stage.template {
      source   = "duration_ms"
      template = "{{ mulf .duration 1000 }}"
    }

    stage.labels {
      values = {
        duration_ms = "",
      }
    }
  }

  // ── Telegram Bot ───────────────────────────
  stage.match {
    selector = "{container=\"dhtaics-telegram-bot\"}"

    stage.regex {
      expression = "^(?P<level>INFO|WARNING|ERROR|DEBUG|CRITICAL)?:?\\s*(?P<message>.+)$"
    }

    stage.template {
      source   = "level"
      template = "{{ if .level }}{{ lower .level }}{{ else }}info{{ end }}"
    }

    stage.labels {
      values = {
        level = "",
      }
    }
  }

  // ── 通用 fallback：沒匹配到的 container ────
  stage.match {
    selector = "{job=\"docker\"}"

    stage.regex {
      expression = "(?i)(?P<level>info|warn|warning|error|fatal|debug|critical)"
    }

    stage.template {
      source   = "level"
      template = "{{ if .level }}{{ lower .level }}{{ else }}info{{ end }}"
    }

    stage.labels {
      values = {
        level = "",
      }
    }
  }

  forward_to = [loki.write.default.receiver]
}

// ─────────────────────────────────────────────
// container recourse
// ─────────────────────────────────────────────

prometheus.exporter.cadvisor "local" {
  docker_host = "unix:///var/run/docker.sock"
  docker_only = true
  disable_root_cgroup_stats = true
  storage_duration = "5m"
}

prometheus.scrape "scraper" {
  targets    = prometheus.exporter.cadvisor.local.targets
  forward_to = [prometheus.remote_write.monitoring.receiver]
}

prometheus.remote_write "monitoring" {
  endpoint {
    url = "http://192.168.157.169:9090/api/v1/write"
  }
}

// ─────────────────────────────────────────────
// 輸出到 Loki
// ─────────────────────────────────────────────
loki.write "default" {
  endpoint {
    url = "http://192.169.157.169:3100/loki/api/v1/push"
  }
}