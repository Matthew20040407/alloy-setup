{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "RAG Stack Log Monitor",
  "uid": "rag-stack-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values(container)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Service Status",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 71,
      "title": "rag_app",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"rag_app\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 72,
      "title": "rag-cache-server",
      "type": "stat",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"rag-cache-server\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 73,
      "title": "qdrant_db",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"qdrant_db\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 74,
      "title": "redis_cache",
      "type": "stat",
      "gridPos": { "x": 9, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"redis_cache\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 75,
      "title": "sip-server",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"sip-server\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 76,
      "title": "dhtaics-telegram-bot",
      "type": "stat",
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"dhtaics-telegram-bot\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },
    {
      "id": 77,
      "title": "alloy",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "count_over_time({container=\"alloy\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "Overview",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 1,
      "title": "Error Count — All Services (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} |~ \"(?i)error\" [5m]))",
          "legendFormat": "{{container}} error"
        },
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} |~ \"(?i)warn\" [5m]))",
          "legendFormat": "{{container}} warn"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 2,
      "title": "Total Errors (1h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 5, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)error\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Warns (1h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 5, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)warn\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Log Volume per Container (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} [5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      }
    },

    {
      "id": 300,
      "type": "row",
      "title": "RAG App",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 10,
      "title": "RAG — Query Pipeline Steps",
      "type": "logs",
      "gridPos": { "x": 0, "y": 14, "w": 16, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{ "expr": "{container=\"rag_app\"} |= \"rag_engine\"" }],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 11,
      "title": "RAG — HTTP Request Count (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \"POST /api\" [5m]))",
          "legendFormat": "POST /api"
        },
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \"200 OK\" [5m]))",
          "legendFormat": "200 OK"
        },
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \" 4\\\\d\\\\d | 5\\\\d\\\\d\" [5m]))",
          "legendFormat": "4xx/5xx"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "title": "RAG — Memory Archive Events",
      "type": "logs",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{ "expr": "{container=\"rag_app\"} |= \"memory_service\"" }],
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 13,
      "title": "RAG — Error / Exception Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"rag_app\"} |~ \"(?i)error|exception|traceback|failed\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 400,
      "type": "row",
      "title": "Qdrant",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 20,
      "title": "Qdrant — Request Rate by Method (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"POST\" [5m]))",
          "legendFormat": "POST (query/upsert)"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"GET\" [5m]))",
          "legendFormat": "GET"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"PUT\" [5m]))",
          "legendFormat": "PUT (upsert)"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 21,
      "title": "Qdrant — Collection Activity",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"test_pdfs\" [5m]))",
          "legendFormat": "test_pdfs"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"user_memory\" [5m]))",
          "legendFormat": "user_memory"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 22,
      "title": "Qdrant — Slow Requests (> 10ms)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 5 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"qdrant_db\"} | regexp \"(?P<duration>[\\\\d\\\\.]+)$\" | duration > 0.01"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },

    {
      "id": 500,
      "type": "row",
      "title": "Redis",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 30,
      "title": "Redis — Warning / Error Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 42, "w": 16, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        { "expr": "{container=\"redis_cache\"} |~ \"WARNING|ERROR|WARN\"" }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 31,
      "title": "Redis — BGSAVE / Persistence Events",
      "type": "logs",
      "gridPos": { "x": 16, "y": 42, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"redis_cache\"} |~ \"BGSAVE|saving|saved|checkpoint|DB loaded\""
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },

    {
      "id": 600,
      "type": "row",
      "title": "SIP Server",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 60,
      "title": "SIP — Call Volume (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 50, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"Call started\" [5m]))",
          "legendFormat": "Calls Started"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"Call ended\" [5m]))",
          "legendFormat": "Calls Ended"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"> INVITE\" [5m]))",
          "legendFormat": "INVITE"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"> BYE\" [5m]))",
          "legendFormat": "BYE"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 61,
      "title": "LLM — Request Rate & Errors (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 50, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"HTTP/1.1 200\" [5m]))",
          "legendFormat": "200 OK"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"500 Internal Server Error\" [5m]))",
          "legendFormat": "500 Error"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"429 Too Many Requests\" [5m]))",
          "legendFormat": "429 Rate Limit"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "500 Error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "429 Rate Limit" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 62,
      "title": "STT — Language Distribution (per 1h)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 50, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"language: zh\" [1h]))",
          "legendFormat": "zh"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"language: en\" [1h]))",
          "legendFormat": "en"
        },
        {
          "expr": "sum(count_over_time({container=\"sip-server\"} |= \"Unsupported language\" [1h]))",
          "legendFormat": "Unsupported fallback"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 63,
      "title": "LLM — Avg Process Time (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 57, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "avg_over_time({container=\"sip-server\"} | regexp \"x-process-time': '(?P<process_time>[\\\\d\\\\.]+)\" | unwrap process_time [5m])",
          "legendFormat": "avg LLM process time (s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 64,
      "title": "STT — Avg Transcription Duration (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 57, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "avg_over_time({container=\"sip-server\"} | regexp \"Transcription complete in (?P<dur>[\\\\d\\\\.]+)s\" | unwrap dur [5m])",
          "legendFormat": "avg STT duration (s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 65,
      "title": "SIP — LLM Error Stream (500 / 429)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 63, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"sip-server\"} |~ \"Chat failed|500 Internal|429 Too Many|Traceback|HTTPStatusError\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 66,
      "title": "SIP — Call Lifecycle Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 70, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"sip-server\"} |~ \"Call started|Call ended|> INVITE|> BYE|> ACK|RING_ANS|> Sent 200 OK|terminated\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 67,
      "title": "SIP — STT / TTS Pipeline Stream",
      "type": "logs",
