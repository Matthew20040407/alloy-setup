      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{host=\"$host\", container=~\"$container\"}",
