      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_memory_working_set_bytes{host=\"$host\", container=~\"$container\", container!=\"\"})",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 32,
      "title": "Container Network RX",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_network_receive_bytes_total{host=\"$host\", container=~\"$container\", container!=\"\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 33,
      "title": "Container Network TX",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 43,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_network_transmit_bytes_total{host=\"$host\", container=~\"$container\", container!=\"\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Logs",
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
