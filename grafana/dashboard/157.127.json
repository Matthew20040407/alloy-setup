{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "157.127 — Host & GPU",
  "uid": "host-157-127",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["host", "gpu", "157.127"],
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "constant",
        "query": "157.127",
        "current": { "text": "157.127", "value": "157.127" },
        "hide": 2
      },
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(container_cpu_usage_seconds_total{host=\"$host\", container!=\"\"}, container)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "gpu",
        "label": "GPU",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL{host=\"$host\"}, gpu)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Host Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "1 - avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\", mode=\"idle\"}[5m]))",
          "legendFormat": "used"
        },
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\", mode=~\"user|system|iowait\"}[5m]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{host=\"$host\"} - node_memory_MemAvailable_bytes{host=\"$host\"}",
          "legendFormat": "used"
        },
        {
          "expr": "node_memory_MemTotal_bytes{host=\"$host\"}",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 12,
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "node_load1{host=\"$host\"}",  "legendFormat": "1m"  },
        { "expr": "node_load5{host=\"$host\"}",  "legendFormat": "5m"  },
        { "expr": "node_load15{host=\"$host\"}", "legendFormat": "15m" }
      ]
    },
    {
      "id": 13,
      "title": "Disk Usage (rootfs)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red",    "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{host=\"$host\", mountpoint=\"/host/root\"} / node_filesystem_size_bytes{host=\"$host\", mountpoint=\"/host/root\"})",
          "legendFormat": "/"
        }
      ]
    },
    {
      "id": 14,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (device) (rate(node_network_receive_bytes_total{host=\"$host\", device!~\"lo|docker.*|veth.*|br-.*\"}[5m]))",
          "legendFormat": "rx {{device}}"
        },
        {
          "expr": "-sum by (device) (rate(node_network_transmit_bytes_total{host=\"$host\", device!~\"lo|docker.*|veth.*|br-.*\"}[5m]))",
          "legendFormat": "tx {{device}}"
        }
      ]
    },

    {
      "id": 2,
      "type": "row",
      "title": "GPU",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "GPU Utilization",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{host=\"$host\", gpu=~\"$gpu\"}",
          "legendFormat": "gpu{{gpu}} {{modelName}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "GPU Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{host=\"$host\", gpu=~\"$gpu\"}",
          "legendFormat": "gpu{{gpu}} used"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE{host=\"$host\", gpu=~\"$gpu\"} + DCGM_FI_DEV_FB_USED{host=\"$host\", gpu=~\"$gpu\"}",
          "legendFormat": "gpu{{gpu}} total"
        }
      ]
    },
    {
      "id": 22,
      "title": "GPU Temperature",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "celsius" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{host=\"$host\", gpu=~\"$gpu\"}",
          "legendFormat": "gpu{{gpu}}"
        }
      ]
    },
    {
      "id": 23,
      "title": "GPU Power Draw",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "watt" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{host=\"$host\", gpu=~\"$gpu\"}",
          "legendFormat": "gpu{{gpu}}"
        }
      ]
    },
    {
      "id": 24,
      "title": "GPU per-Container Usage (DCGM)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "description": "Per-container GPU utilization from DCGM exporter. Empty if container labels are not being attached — fall back to panel below.",
      "targets": [
        {
          "expr": "sum by (container_name, gpu) (DCGM_FI_DEV_GPU_UTIL{host=\"$host\", container_name!=\"\"})",
          "legendFormat": "{{container_name}} gpu{{gpu}}"
        }
      ]
    },
    {
      "id": 25,
      "title": "GPU per-Container (cAdvisor accelerator)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "description": "Alternative per-container GPU view from cAdvisor's NVML integration.",
      "targets": [
        {
          "expr": "container_accelerator_duty_cycle{host=\"$host\", container=~\"$container\"}",
          "legendFormat": "{{container}} {{make}} {{model}}"
        }
      ]
    },
    {
      "id": 26,
      "title": "GPU per-Container Memory (cAdvisor)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "container_accelerator_memory_used_bytes{host=\"$host\", container=~\"$container\"}",
          "legendFormat": "{{container}} {{model}}"
        }
      ]
    },

    {
      "id": 3,
      "type": "row",
      "title": "Containers",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Container CPU",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_cpu_usage_seconds_total{host=\"$host\", container=~\"$container\", container!=\"\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 31,
      "title": "Container Memory (working set)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (container) (container_memory_working_set_bytes{host=\"$host\", container=~\"$container\", container!=\"\"})",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 32,
      "title": "Container Network RX",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 43, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_network_receive_bytes_total{host=\"$host\", container=~\"$container\", container!=\"\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 33,
      "title": "Container Network TX",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 43, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_network_transmit_bytes_total{host=\"$host\", container=~\"$container\", container!=\"\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },

    {
      "id": 4,
      "type": "row",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 40,
      "title": "Container Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{host=\"$host\", container=~\"$container\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
