{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "RAG Stack — Detailed Log Monitor",
  "uid": "rag-stack-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values(container)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "📊 Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 1,
      "title": "Error Count — All Services (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 16, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} | label_format level=level |~ \"(?i)error\" [5m]))",
          "legendFormat": "{{container}} error"
        },
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} | label_format level=level |~ \"(?i)warn\" [5m]))",
          "legendFormat": "{{container}} warn"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 2,
      "title": "Total Errors (1h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)error\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Warns (1h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)warn\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Log Volume per Container (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({job=\"docker\", container=~\"$container\"} [5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      }
    },

    {
      "id": 101,
      "type": "row",
      "title": "🤖 RAG App",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 10,
      "title": "RAG — Query Pipeline Steps",
      "type": "logs",
      "gridPos": { "x": 0, "y": 10, "w": 16, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{ "expr": "{container=\"rag_app\"} |= \"rag_engine\"" }],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 11,
      "title": "RAG — HTTP Request Count (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \"POST /api\" [5m]))",
          "legendFormat": "POST /api"
        },
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \"200 OK\" [5m]))",
          "legendFormat": "200 OK"
        },
        {
          "expr": "sum(count_over_time({container=\"rag_app\"} |~ \" 4\\\\d\\\\d | 5\\\\d\\\\d\" [5m]))",
          "legendFormat": "4xx/5xx"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "title": "RAG — Memory Archive Events",
      "type": "logs",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{ "expr": "{container=\"rag_app\"} |= \"memory_service\"" }],
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 13,
      "title": "RAG — Error / Exception Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"rag_app\"} |~ \"(?i)error|exception|traceback|failed\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 102,
      "type": "row",
      "title": "🗄️ Qdrant",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 20,
      "title": "Qdrant — Request Rate by Method (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"qdrant\"} |= \"POST\" [5m]))",
          "legendFormat": "POST (query/upsert)"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant\"} |= \"GET\" [5m]))",
          "legendFormat": "GET"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant\"} |= \"PUT\" [5m]))",
          "legendFormat": "PUT (upsert)"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 21,
      "title": "Qdrant — Collection Activity",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"test_pdfs\" [5m]))",
          "legendFormat": "test_pdfs"
        },
        {
          "expr": "sum(count_over_time({container=\"qdrant_db\"} |= \"user_memory\" [5m]))",
          "legendFormat": "user_memory"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 22,
      "title": "Qdrant — Slow Requests (> 10ms)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 5 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"qdrant_db\"} | regex \"(?P<duration>[\\\\d\\\\.]+)$\" | duration > 0.01"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },

    {
      "id": 103,
      "type": "row",
      "title": "🔴 Redis",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 30,
      "title": "Redis — Warning / Error Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 38, "w": 16, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"redis_cache\"} |~ \"WARNING|ERROR|WARN\" | label_format level=level"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 31,
      "title": "Redis — BGSAVE / Persistence Events",
      "type": "logs",
      "gridPos": { "x": 16, "y": 38, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container=\"redis_cache\"} |~ \"BGSAVE|saving|saved|checkpoint|DB loaded\""
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },

    {
      "id": 104,
      "type": "row",
      "title": "🤖 Telegram Bot",
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 40,
      "title": "Telegram Bot — All Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{ "expr": "{container=\"dhtaics-telegram-bot\"}" }],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 105,
      "type": "row",
      "title": "📞 SIP Server",
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 60,
      "title": "SIP — Call Volume (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 53, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"Call started\" [5m]))",
          "legendFormat": "Calls Started"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"Call ended\" [5m]))",
          "legendFormat": "Calls Ended"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"> INVITE\" [5m]))",
          "legendFormat": "INVITE"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"> BYE\" [5m]))",
          "legendFormat": "BYE"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 61,
      "title": "LLM — Request Rate & Errors (per 5m)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 53, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"HTTP/1.1 200\" [5m]))",
          "legendFormat": "200 OK"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"500 Internal Server Error\" [5m]))",
          "legendFormat": "500 Error"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"429 Too Many Requests\" [5m]))",
          "legendFormat": "429 Rate Limit"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "500 Error" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "429 Rate Limit" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 62,
      "title": "STT — Language Distribution (per 1h)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 53, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"language: zh\" [1h]))",
          "legendFormat": "zh 中文"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"language: en\" [1h]))",
          "legendFormat": "en English"
        },
        {
          "expr": "sum(count_over_time({job=\"sip_server\"} |= \"Unsupported language\" [1h]))",
          "legendFormat": "Unsupported fallback"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      }
    },
    {
      "id": 63,
      "title": "LLM — Avg Process Time (x-process-time header)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 60, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "avg_over_time({job=\"sip_server\"} | regexp \"x-process-time': '(?P<process_time>[\\\\d\\\\.]+)\" | unwrap process_time [5m])",
          "legendFormat": "avg LLM process time (s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 64,
      "title": "STT — Transcription Duration (per call)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 60, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "avg_over_time({job=\"sip_server\"} | regexp \"Transcription complete in (?P<dur>[\\\\d\\\\.]+)s\" | unwrap dur [5m])",
          "legendFormat": "avg STT duration (s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 65,
      "title": "SIP — LLM Error Stream (500 / 429)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 66, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"sip_server\"} |~ \"Chat failed|500 Internal|429 Too Many|Traceback|HTTPStatusError\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 66,
      "title": "SIP — Call Lifecycle Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 73, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"sip_server\"} |~ \"Call started|Call ended|> INVITE|> BYE|> ACK|RING_ANS|> Sent 200 OK|terminated\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 67,
      "title": "SIP — STT / TTS Pipeline Stream",
      "type": "logs",
      "gridPos": { "x": 12, "y": 73, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"sip_server\"} |~ \"Transcription complete|Detected language|Generating response|LLM Response|Synthesizing|TTS audio saved|Unsupported language\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 106,
      "type": "row",
      "title": "🔍 Full Error Stream — All Services",
      "gridPos": { "x": 0, "y": 80, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 50,
      "title": "All Errors / Exceptions (即時)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 81, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=~\"docker|sip_server\"} |~ \"(?i)error|exception|traceback|fatal|panic|critical|Chat failed|429\""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
